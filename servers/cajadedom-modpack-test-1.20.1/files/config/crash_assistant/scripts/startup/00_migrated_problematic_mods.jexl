var allMods = ModListUtils.getCurrentModList(true);
var mods = ModListUtils.getCurrentModListMappedToModId();

var m_tlskincape = mods.get("tlskincape");
if (m_tlskincape != null) {
    var warn = Startup.addCrashWarning("It seems that you are using <strong>TLauncher</strong>! This modpack has been done with a lot of sweat, blood and tears. Downloading this modpack from a pirated copy of minecraft, that also has spyware integrated into it, neither helps us improve this modpack, nor does it keep your files and passwords safe. We strongly suggest you get rid of TlLauncher and get a proper copy of minecraft.");
    warn.withModActions(m_tlskincape);
    Startup.markForCrash();
}

var m_epicfight = mods.get("epicfight");
if (m_epicfight != null) {
    var warn = Startup.addCrashWarning("It appears you have added <strong>Epic Fight</strong> to the Modpack. <strong>Epic Fight</strong> is incompatible with Prominence's core mod and the mods inside as the main combat system is Better Combat. You cannot remove Better Combat to make <strong>Epic Fight</strong> work. This will break the game.");
    warn.withModActions(m_epicfight);
    Startup.markForCrash();
}

var m_valkyrienskies = mods.get("valkyrienskies");
if (m_valkyrienskies != null) {
    var warn = Startup.addBootWarning("It appears you have added <strong>Valkyrienskies</strong> to the modpack. <strong>Valkyrienskies</strong> is incompatible with Sodium and the current version of create. Use at your own risk.");
    warn.withModActions(m_valkyrienskies);
}

var m_optifine = mods.get("optifine");
if (m_optifine != null) {
    var warn = Startup.addCrashWarning("It appears you have added <strong>Optifine</strong> to the Modpack. <strong>Optifine mod</strong> is incompatible with the pack as it is not necessary at all, Prominence uses Sodium and Iris, which do the same as Optifine, but better. If you have Performance issues please visit https://rpg.prominence.wiki/performance-guide as well as https://github.com/Mukul1127/Minecraft-Java-Flags");
    warn.withModActions(m_optifine);
    Startup.markForCrash();
}

var m_memoryleakfix = mods.get("memoryleakfix");
if (m_memoryleakfix != null) {
    var warn = Startup.addCrashWarning("It appears you have added <strong>Memoryleakfix</strong> to the Modpack. <strong>Memoryleakfix</strong> is incompatible with the pack as it causes a ton of Problems with Prominence's Chunkloading and will make Chunks not load properly or at all. It decreases your Performance more than anything.");
    warn.withModActions(m_memoryleakfix);
    Startup.markForCrash();
}

var m_opac_fabric_create_support = mods.get("opac-fabric-create-support");
if (m_opac_fabric_create_support != null) {
    var warn = Startup.addCrashWarning("It appears you have added <strong>Create Support for Open Parties and Claims</strong> to the Modpack. <strong>Create Support for Open Parties and Claims</strong> is obsolete. If this is still in your Modpack you most likely didnt update the game properly.");
    warn.withModActions(m_opac_fabric_create_support);
    Startup.markForCrash();
}

var m_mc_betterstats = mods.get("mc-betterstats");
if (m_mc_betterstats != null) {
    var warn = Startup.addCrashWarning("It appears you have added <strong>Betterstats</strong> to the Modpack. <strong>Betterstats</strong> is incompatible with the pack as it sends giant packets to anyone on the server, which makes any server crash or disconnects/crashes its players.");
    warn.withModActions(m_mc_betterstats);
    Startup.markForCrash();
}

